{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: gcc.exe 生成活动文件",
      "command": "C:/mingw64/bin/gcc.exe",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}", // 编译当前打开的.c文件
        "-o",
        // 生成的exe放在当前代码目录下
        "${fileDirname}\\${fileBasenameNoExtension}.exe",
        "-Wall" // 显示所有警告（方便排查代码错误）
      ],
      // 关键：工作目录改为代码所在目录
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "编译器: C:/mingw64/bin/gcc.exe"
    }
  ],
  "version": "2.0.0"
}
